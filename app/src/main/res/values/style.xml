<resources xmlns:tools="http://schemas.android.com/tools">
    <!--  ============================================================
             TEXTOS
             ============================================================  -->
    <style name="TextAppEyebrow">
        <item name="android:textColor">@color/accent_cyan</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.18</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="TextAppHeroTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">30sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="TextAppHeroSubtitle">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>
    <!--  Título grande usado em telas com fundo "cyber" (login / admin)  -->
    <style name="TextCyberTitle" parent="TextAppHeroTitle">
        <item name="android:letterSpacing">0.01</item>
    </style>
    <style name="TextCyberSubtitle" parent="TextAppHeroSubtitle"/>
    <style name="TextAppSectionTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TextAppBody">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">3dp</item>
    </style>
    <!--  Tag/badge pequena, tipo "chip" cyberpunk: OKHTTP3, MVVM, ALIVE...  -->
    <style name="CyberTag">
        <item name="android:background">@drawable/bg_chip_neon</item>
        <item name="android:paddingHorizontal">10dp</item>
        <item name="android:paddingVertical">5dp</item>
        <item name="android:textColor">@color/accent_cyan</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:gravity">center</item>
    </style>
    <!--  ============================================================
             CARDS
             ============================================================  -->
    <style name="CardAppGlass" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface_glass</item>
        <item name="cardCornerRadius">@dimen/radius_large</item>
        <item name="cardElevation">@dimen/elevation_card</item>
        <item name="strokeColor">@color/border_glass</item>
        <item name="strokeWidth">1dp</item>
    </style>
    <!--  ============================================================
             BOTÕES
             ============================================================  -->
    <style name="ButtonAppPrimary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/accent_cyan</item>
        <item name="android:textColor">@color/background_dark</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">@dimen/radius_medium</item>
    </style>
    <style name="ButtonAppSecondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/accent_cyan</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/accent_cyan</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">@dimen/radius_medium</item>
    </style>
    <style name="ButtonAppText" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textAllCaps">false</item>
    </style>
    <!--  ============================================================
             CAMPOS DE TEXTO
             ============================================================  -->
    <style name="InputCyber" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface_glass</item>
        <item name="boxStrokeColor">@color/accent_cyan</item>
        <item name="boxCornerRadiusTopStart">@dimen/radius_medium</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_medium</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_medium</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_medium</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
    </style>
    <style name="InputAppDropdown" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">
        <item name="boxBackgroundColor">@color/surface_glass</item>
        <item name="boxStrokeColor">@color/border_glass</item>
        <item name="boxCornerRadiusTopStart">@dimen/radius_medium</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_medium</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_medium</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_medium</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
    </style>
</resources>