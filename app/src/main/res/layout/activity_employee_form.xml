<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <TextView
            style="@style/TextAppEyebrow"
            android:background="@drawable/bg_chip"
            android:paddingHorizontal="@dimen/space_16"
            android:paddingVertical="@dimen/space_8"
            android:text="FORMULÁRIO"
            android:textColor="@color/app_secondary" />

        <TextView
            android:id="@+id/titleTextView"
            style="@style/TextAppHeroTitle"
            android:layout_width="match_parent"
            android:layout_marginTop="@dimen/space_16"
            android:text="Funcionário" />

        <TextView
            style="@style/TextAppHeroSubtitle"
            android:layout_width="match_parent"
            android:layout_marginTop="@dimen/space_6"
            android:text="Preencha os dados para sincronizar com o backend Grails." />

        <com.google.android.material.card.MaterialCardView
            style="@style/CardAppGlass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_24"
            app:strokeColor="@color/app_secondary_subtle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_20">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/nameInputLayout"
                    style="@style/InputCyber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nome"
                    app:boxStrokeColor="@color/app_secondary"
                    app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                    app:startIconTint="@color/app_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/nameEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/emailInputLayout"
                    style="@style/InputCyber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:hint="E-mail"
                    app:boxStrokeColor="@color/app_secondary"
                    app:startIconDrawable="@android:drawable/ic_dialog_email"
                    app:startIconTint="@color/app_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/emailEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/roleInputLayout"
                    style="@style/InputCyber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:hint="Cargo"
                    app:boxStrokeColor="@color/app_secondary"
                    app:startIconDrawable="@android:drawable/ic_menu_manage"
                    app:startIconTint="@color/app_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/roleEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/salaryInputLayout"
                    style="@style/InputCyber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:hint="Salário"
                    app:boxStrokeColor="@color/app_secondary"
                    app:startIconDrawable="@android:drawable/ic_menu_sort_by_size"
                    app:startIconTint="@color/app_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/salaryEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/activeSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_16"
                    android:checked="true"
                    android:text="Funcionário ativo"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    app:thumbTint="@color/app_secondary"
                    app:trackTint="@color/app_secondary_subtle" />

                <ProgressBar
                    android:id="@+id/loadingProgressBar"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/space_16"
                    android:indeterminateTint="@color/app_secondary"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/saveButton"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/space_24"
                    android:text="Salvar"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    app:backgroundTint="@color/app_secondary"
                    app:cornerRadius="@dimen/radius_medium" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>