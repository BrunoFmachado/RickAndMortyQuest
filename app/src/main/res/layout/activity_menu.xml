<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_void"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#1A00F0FF"
            android:fontFamily="monospace"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text=">_ SYS_ADMIN_AUTH"
            android:textColor="@color/neon_cyan"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/titleTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Olá, Administrador"
            android:textColor="@color/text_bright"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/emailTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="admin@empresa.com • Acesso Nível 5"
            android:textColor="@color/text_muted"
            android:textSize="14sp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OKHTTP3"
                    android:textColor="@color/neon_cyan"
                    app:chipBackgroundColor="@color/neon_cyan_alpha"
                    app:chipStrokeColor="@color/neon_cyan"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="MVVM"
                    android:textColor="@color/neon_cyan"
                    app:chipBackgroundColor="@color/neon_cyan_alpha"
                    app:chipStrokeColor="@color/neon_cyan"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="GRAILS"
                    android:textColor="@color/neon_cyan"
                    app:chipBackgroundColor="@color/neon_cyan_alpha"
                    app:chipStrokeColor="@color/neon_cyan"
                    app:chipStrokeWidth="1dp" />
            </LinearLayout>
        </HorizontalScrollView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/charactersCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/surface_glass"
            app:cardCornerRadius="8dp"
            app:strokeColor="@color/neon_cyan"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DIMENSÃO C-137"
                    android:textColor="@color/text_bright"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Integração de API. Realiza paginação, filtros complexos e varredura biométrica via câmera."
                    android:textColor="@color/text_muted"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/openCharactersButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:text="NAVEGAR"
                    android:textColor="@color/bg_void"
                    android:textStyle="bold"
                    app:backgroundTint="@color/neon_cyan"
                    app:cornerRadius="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/employeesCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/surface_glass"
            app:cardCornerRadius="8dp"
            app:strokeColor="#33FFFFFF"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="EMPLOYEE CORE"
                    android:textColor="@color/text_bright"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Backend Grails local. Gerenciamento total de equipe com persistência MySQL e endpoints REST."
                    android:textColor="@color/text_muted"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/openEmployeesButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:text="NAVEGAR"
                    android:textColor="@color/bg_void"
                    android:textStyle="bold"
                    app:backgroundTint="@color/neon_cyan"
                    app:cornerRadius="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/logoutButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="40dp"
            android:fontFamily="monospace"
            android:text="ENCERRAR SESSÃO"
            android:textColor="@color/neon_magenta"
            app:backgroundTint="@android:color/transparent"
            app:cornerRadius="4dp"
            app:strokeColor="@color/neon_magenta"
            app:strokeWidth="1dp" />

    </LinearLayout>
</ScrollView>