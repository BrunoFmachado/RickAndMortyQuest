<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <ImageView
        android:id="@+id/portalGlow"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/bg_portal_glow"
        android:alpha="0.8"
        app:layout_constraintBottom_toTopOf="@id/titleTextView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/logoTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="R&amp;M"
        android:textColor="@color/accent_cyan"
        android:textSize="48sp"
        android:textStyle="bold"
        android:letterSpacing="-0.05"
        app:layout_constraintBottom_toBottomOf="@id/portalGlow"
        app:layout_constraintEnd_toEndOf="@id/portalGlow"
        app:layout_constraintStart_toStartOf="@id/portalGlow"
        app:layout_constraintTop_toTopOf="@id/portalGlow" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="150dp"
        android:layout_height="2dp"
        android:layout_marginTop="24dp"
        style="?android:attr/progressBarStyleHorizontal"
        android:progressTint="@color/accent_cyan"
        android:indeterminate="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleTextView" />

</androidx.constraintlayout.widget.ConstraintLayout>