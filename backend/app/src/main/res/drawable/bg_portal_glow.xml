<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:centerColor="#6631F7FF"
                android:endColor="#0031F7FF"
                android:gradientRadius="120dp" />
        </shape>
    </item>

    <item
        android:width="168dp"
        android:height="168dp"
        android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="#2212D8FA" />
            <stroke
                android:width="2dp"
                android:color="#8831F7FF" />
        </shape>
    </item>

    <item
        android:width="118dp"
        android:height="118dp"
        android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="#3328FFBF" />
            <stroke
                android:width="1dp"
                android:color="#AA9DFF3A" />
        </shape>
    </item>

</layer-list>